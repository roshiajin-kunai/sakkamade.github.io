---
layout: null
---
<?xml version="1.0" encoding="UTF-8"?>
<feed xmlns="http://www.w3.org/2005/Atom" >
    {%- include /feed/feed-head.xml -%}
    <title type="html">{{ site.title | xml_escape }}</title>
    <link href="{{ site.url }}/feed.xml" rel="self" type="application/atom+xml"/>
    <id>https://sakkamade.github.io/feed.xml</id>
        {% for post in site.posts limit: 13 %}<entry>
            {%- include /feed/feed-post-summary.xml -%}
            <published>{{ post.date | date_to_xmlschema }}</published>
            <updated>{% if post.last_modified_at %}{{ post.last_modified_at | date_to_xmlschema }}{% else %}{{ post.date | date_to_xmlschema }}{% endif %}</updated>
        </entry>{% endfor %}
</feed>
